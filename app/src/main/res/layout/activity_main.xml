<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <ImageButton
        android:id="@+id/btnPower"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/bg_power_button"
        android:contentDescription="@string/shutdown"
        android:src="@drawable/ic_power"
        android:padding="28dp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toTopOf="@id/tvLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.45" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/shutdown"
        android:textColor="#CC444444"
        android:textSize="13sp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-light"
        app:layout_constraintTop_toBottomOf="@id/btnPower"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
